{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "controle-financeiro-familiar",
  "version": "0.1.0",
  "identifier": "com.paulo.controle-financeiro-familiar",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "controle-financeiro-familiar",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "maximized": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "sidebarImage": "installer/sidebar.bmp",
        "languages": ["PortugueseBR"],
        "displayLanguageSelector": false
      }
    }
  }
}
